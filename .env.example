# Docker / compose naming
DOCKER_IMAGE=hanyangauto
CONTAINER_NAME=hanyangauto

# Front service / reverse proxy
DOMAIN=localhost
PORT=8000

# Required application secrets
# Generate a 32-byte key with:
#   openssl rand -base64 32
DB_ENCRYPTION_KEY_B64=REPLACE_WITH_BASE64_32BYTE_KEY
SESSION_SECRET_B64=REPLACE_WITH_BASE64_32BYTE_KEY

# Optional runtime settings
ADMIN_INITIAL_PASSWORD=change-me-admin-password
RECEIVE_SERVER_URL=http://automation:7000
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
PLAYWRIGHT_HEADLESS=true
